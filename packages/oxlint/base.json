{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "fix": {
          "imports": "safe-fix",
          "variables": "safe-fix"
        }
      }
    ]
  }
}
